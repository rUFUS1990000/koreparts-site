# Публичный URL сайта (без слэша в конце)
# На Vercel: Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=https://koreparts-site.vercel.app

# ——— Web3Forms (заявки и заказы на email) ———
# Публичный access key: https://web3forms.com
# Работает и на static / reg.ru (ключ вшивается в клиент — так задумано)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# ——— Вход VK / Яндекс (OAuth) ———
# Redirect URI в кабинетах приложений (оба варианта):
#   https://ваш-домен.ru/auth/callback/
#   http://localhost:3000/auth/callback/
# Яндекс ID: https://oauth.yandex.ru/ → создать приложение → ClientID
NEXT_PUBLIC_YANDEX_CLIENT_ID=
# VK: https://dev.vk.com/ → приложение → ID приложения
NEXT_PUBLIC_VK_APP_ID=

# ——— ИИ-помощник (xAI / Grok) ———
# Ключ: https://console.x.ai  (никогда не публикуйте в git / на клиенте)
# Работает только на Node/Vercel (не на чистом static reg.ru)
XAI_API_KEY=
# Опционально, по умолчанию grok-4.5
# XAI_MODEL=grok-4.5
