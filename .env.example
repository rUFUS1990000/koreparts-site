# Публичный URL сайта (без слэша в конце)
# На Vercel: Settings → Environment Variables
# После деплоя подставьте ваш домен, например:
# https://koreparts-site.vercel.app
NEXT_PUBLIC_SITE_URL=https://koreparts-site.vercel.app

# Опционально: ссылка на Telegram-бот (если меняете)
# NEXT_PUBLIC_TELEGRAM_BOT=KorePartsBot
